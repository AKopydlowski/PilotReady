# PilotReady environment configuration.
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env        (PowerShell:  Copy-Item .env.example .env)
#
# `.env` is gitignored and must never be committed.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Point this at YOUR development database (the one you can see in pgAdmin),
# NOT the default "postgres" maintenance database. Create it first, e.g.:
#     CREATE DATABASE pilotready;
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/YOUR_DB_NAME

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API (the Vite dev server
# runs on 5173 by default). In production add your Vercel URL, e.g.:
#     CORS_ORIGINS=http://localhost:5173,https://pilotready.vercel.app
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Auth / security
# -----------------------------------------------------------------------------
# Secret used to sign session tokens (JWT). MUST be long and random in
# production — anyone who knows it can forge logins. Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left unset, the backend generates a random ephemeral secret on each start
# (fine for local dev; sessions reset on restart).
JWT_SECRET=

# How long a login stays valid, in minutes (default 10080 = 7 days).
JWT_EXPIRE_MINUTES=10080

# Comma-separated emails that get admin rights (e.g. the support panel).
# Only these accounts can see/triage other users' reports.
ADMIN_EMAILS=akkraofficialone@gmail.com

# -----------------------------------------------------------------------------
# Frontend (Vite) — only VITE_* vars are exposed to the browser
# -----------------------------------------------------------------------------
# Public URL of the backend API. Leave EMPTY in local dev (Vite proxies /api to
# 127.0.0.1:8000). In production (Vercel) set it to your Render backend URL:
#     VITE_API_URL=https://pilotready-api.onrender.com
VITE_API_URL=
